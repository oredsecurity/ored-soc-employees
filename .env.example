# ═══════════════════════════════════════════════
# ORED AI SOC Employees — Environment Configuration
# ═══════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# REQUIRED fields are marked. Everything else has sensible defaults.

# ── Wazuh API Connection (REQUIRED) ──────────
WAZUH_HOST=https://your-wazuh-manager.example.com
WAZUH_PORT=55000
WAZUH_USER=wazuh-wui
WAZUH_PASS=CHANGE_ME
WAZUH_VERIFY_SSL=false

# ── Wazuh Indexer (Optional, needed for vuln tools on Wazuh 4.8+) ──
# WAZUH_INDEXER_HOST=your-indexer.example.com
# WAZUH_INDEXER_PORT=9200
# WAZUH_INDEXER_USER=admin
# WAZUH_INDEXER_PASS=admin

# ── LLM Backend (REQUIRED for full-stack mode) ──
# Works with any OpenAI-compatible provider: Anthropic, OpenRouter, MiniMax, etc.
# Set LLM_BASE_URL to your provider's endpoint and LLM_API_KEY to your key.
#
# Examples:
#   Anthropic (default):  LLM_BASE_URL=https://api.anthropic.com  LLM_API_KEY=sk-ant-...
#   OpenRouter:           LLM_BASE_URL=https://openrouter.ai/api/v1  LLM_API_KEY=sk-or-...
#   MiniMax:              LLM_BASE_URL=https://api.minimax.chat/v1  LLM_API_KEY=...
#   Local (Ollama):       LLM_BASE_URL=http://host.docker.internal:11434/v1  LLM_API_KEY=unused
#
LLM_API_KEY=***
# LLM_BASE_URL=https://api.anthropic.com
# LLM_MODEL=claude-sonnet-4-20250514

# ── MCP Server Settings ──────────────────────
MCP_PORT=3000
MCP_AUTH_MODE=none
# MCP_AUTH_SECRET=*** Generate with: openssl rand -hex 32

# ── Telegram Approval Bot (Optional) ─────────
# TELEGRAM_BOT_TOKEN=***
# TELEGRAM_CHAT_ID=your-chat-id

# ── Alert Polling ───────────────────────────
ORED_POLL_ENABLED=true
ORED_POLL_INTERVAL=60
ORED_POLL_MIN_LEVEL=5
ORED_POLL_BATCH_SIZE=100

# ── Logging ──────────────────────────────────
LOG_LEVEL=INFO
