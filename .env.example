# ORED AI SOC Employees — Environment Variables
# Copy to .env and fill in your values:  cp .env.example .env

# ── Wazuh API Connection ─────────────────────────────────────────────
WAZUH_HOST=https://your-wazuh-manager
WAZUH_PORT=55000
WAZUH_USER=wazuh-wui
WAZUH_PASS=
WAZUH_VERIFY_SSL=false

# ── Wazuh Indexer (optional, for vulnerability tools on Wazuh 4.8+) ──
WAZUH_INDEXER_HOST=
WAZUH_INDEXER_PORT=9200
WAZUH_INDEXER_USER=
WAZUH_INDEXER_PASS=

# ── MCP Server ────────────────────────────────────────────────────────
MCP_PORT=3000
MCP_AUTH_MODE=none
MCP_AUTH_SECRET_KEY=

# ── Alert Polling ─────────────────────────────────────────────────────
ORED_POLL_ENABLED=true
ORED_POLL_INTERVAL=60
ORED_POLL_MIN_LEVEL=5
ORED_POLL_BATCH_SIZE=100

# ── LLM Backend ──────────────────────────────────────────────────────
# LLM_PROVIDER: anthropic, minimax, deepseek, openrouter, openai
#   If not set, auto-detected from model name.
# LLM_BASE_URL: Only needed for custom endpoints. Leave empty for
#   native providers (Anthropic, MiniMax, OpenRouter).
LLM_PROVIDER=
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# ── Telegram Approval Interface ──────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Logging ───────────────────────────────────────────────────────────
LOG_LEVEL=INFO
