# ORED AI SOC Employees - MCP Server Environment
# Copy to .env and fill in your values:  cp .env.example .env
#
# This configures the Wazuh MCP server container only.
# Hermes agent config (LLM keys, Telegram) lives in the Hermes profile.
# See: scripts/provision-tenant.sh for automated setup.

# -- Wazuh API Connection ------------------------------------------------
WAZUH_HOST=https://your-wazuh-manager
WAZUH_PORT=55000
WAZUH_USER=wazuh-wui
WAZUH_PASS=
WAZUH_VERIFY_SSL=false

# -- Wazuh Indexer (optional, for vulnerability tools on Wazuh 4.8+) -----
WAZUH_INDEXER_HOST=
WAZUH_INDEXER_PORT=9200
WAZUH_INDEXER_USER=
WAZUH_INDEXER_PASS=

# -- MCP Server -----------------------------------------------------------
MCP_PORT=3000
LOG_LEVEL=INFO

# -- Alert Polling --------------------------------------------------------
ORED_POLL_ENABLED=true
ORED_POLL_INTERVAL=60
ORED_POLL_MIN_LEVEL=5
ORED_POLL_BATCH_SIZE=100

# -- Telegram Approval Bot (for MCP server-side approval) -----------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
