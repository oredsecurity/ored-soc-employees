# ═══════════════════════════════════════════════
# ORED AI SOC Employees — Environment Configuration
# ═══════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# REQUIRED fields are marked. Everything else has sensible defaults.

# ── Wazuh API Connection (REQUIRED) ──────────
WAZUH_HOST=https://your-wazuh-manager.example.com
WAZUH_PORT=55000
WAZUH_USER=wazuh-wui
WAZUH_PASS=CHANGE_ME
WAZUH_VERIFY_SSL=false

# ── Wazuh Indexer (Optional — needed for vuln tools on Wazuh 4.8+) ──
# WAZUH_INDEXER_HOST=your-indexer.example.com
# WAZUH_INDEXER_PORT=9200
# WAZUH_INDEXER_USER=admin
# WAZUH_INDEXER_PASS=admin

# ── LLM Backend (REQUIRED — at least one) ────
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
# OPENROUTER_API_KEY=sk-or-CHANGE_ME

# ── MCP Server Settings ──────────────────────
MCP_PORT=3000
MCP_AUTH_MODE=none
# MCP_AUTH_SECRET=  # Generate with: openssl rand -hex 32

# ── Telegram Approval Bot (Optional for Phase 1) ──
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_CHAT_ID=your-chat-id

# ── Logging ──────────────────────────────────
LOG_LEVEL=INFO
