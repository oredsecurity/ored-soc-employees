# ORED AI SOC Employees — Environment Variables
# Copy to .env and fill in your values:  cp .env.example .env

# ── Wazuh API Connection ─────────────────────────────────────────────
WAZUH_HOST=https://your-wazuh-manager
WAZUH_PORT=55000
WAZUH_USER=wazuh-wui
WAZUH_PASS=
WAZUH_VERIFY_SSL=false

# ── Wazuh Indexer (optional, for vulnerability tools on Wazuh 4.8+) ──
WAZUH_INDEXER_HOST=
WAZUH_INDEXER_PORT=9200
WAZUH_INDEXER_USER=
WAZUH_INDEXER_PASS=

# ── MCP Server ────────────────────────────────────────────────────────
MCP_PORT=3000
MCP_AUTH_MODE=none
MCP_AUTH_SECRET_KEY=

# ── Alert Polling ─────────────────────────────────────────────────────
ORED_POLL_ENABLED=true
ORED_POLL_INTERVAL=60
ORED_POLL_MIN_LEVEL=5
ORED_POLL_BATCH_SIZE=100

# ── LLM Backend (any OpenAI-compatible provider) ─────────────────────
# Supported providers: anthropic, minimax, deepseek, openrouter, or any OpenAI-compatible
# The installer auto-detects the provider from LLM_BASE_URL if LLM_PROVIDER is not set
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
LLM_PROVIDER=

# ── Telegram Approval Interface ──────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Logging ───────────────────────────────────────────────────────────
LOG_LEVEL=INFO
